{
  "name": "obuild",
  "version": "0.4.33",
  "description": "Zero-config ESM/TS package builder",
  "license": "MIT",
  "repository": "unjs/obuild",
  "bin": {
    "obuild": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./config": "./dist/config.mjs"
  },
  "scripts": {
    "build": "pnpm obuild",
    "dev": "pnpm vitest",
    "lint": "oxlint . && oxfmt --check",
    "fmt": "automd && oxlint . --fix && oxfmt",
    "obuild": "node ./src/cli.ts",
    "release": "pnpm test && pnpm build && changelogen --release && npm publish && git push --follow-tags",
    "test": "pnpm lint && pnpm test:types && pnpm vitest run --coverage",
    "test:types": "tsgo --noEmit --skipLibCheck"
  },
  "dependencies": {
    "c12": "^4.0.0-beta.4",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "exsolve": "^1.0.8",
    "magic-string": "^0.30.21",
    "pathe": "^2.0.3",
    "pretty-bytes": "^7.1.0",
    "rolldown": "^1.0.0-rc.16",
    "rolldown-plugin-dts": "^0.23.2",
    "rollup-plugin-license": "^3.7.1",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260418.1",
    "@vitest/coverage-v8": "^4.1.4",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "eslint-config-unjs": "^0.6.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "resolutions": {
    "obuild": "link:."
  },
  "packageManager": "pnpm@10.33.0"
}
